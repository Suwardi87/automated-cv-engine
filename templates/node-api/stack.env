DISPLAY_NAME="NestJS 11 API"
DESCRIPTION="NestJS REST API with TypeORM, JWT, Bull/Redis"
DETECT_FILES="backend/package.json"
DETECT_EXCLUDE=""
DETECT_PRIORITY=15

PACKAGE_MANAGER_DETECT="pnpm-lock.yaml:pnpm install --frozen-lockfile yarn.lock:yarn install --frozen-lockfile package-lock.json:npm ci bun.lock:bun install"
PACKAGE_MANAGER_FALLBACK="npm install"

LINT_CMD="cd backend && npx eslint \"src/**/*.ts\""
TYPECHECK_CMD="cd backend && npx nest build"
TEST_CMD="cd backend && npm run test --if-present"

SECURITY_AUDIT_CMD="cd backend && npm audit --audit-level=moderate 2>/dev/null || true"
SECURITY_HTML_CMD=""
SECURITY_EXTRA_CMD=""

VERSION_SOURCE="file"
VERSION_FILE="VERSION"
