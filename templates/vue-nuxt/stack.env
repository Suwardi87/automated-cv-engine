DISPLAY_NAME="Nuxt 4 + NestJS Monorepo"
DESCRIPTION="Fullstack monorepo: Nuxt 4 (SSR/Vue 3) + NestJS (REST API)"
DETECT_FILES="package.json"
DETECT_EXCLUDE=""
DETECT_PRIORITY=10

# Package manager: cek lockfile urut
PACKAGE_MANAGER_DETECT="pnpm-lock.yaml:pnpm install --frozen-lockfile yarn.lock:yarn install --frozen-lockfile package-lock.json:npm ci bun.lock:bun install"
PACKAGE_MANAGER_FALLBACK="npm install"

# Monorepo: lint + typecheck untuk frontend (Nuxt) + backend (NestJS)
LINT_CMD="cd frontend-cms && npx nuxi typecheck"
TYPECHECK_CMD="cd frontend-cms && npx nuxi typecheck"
TEST_CMD="cd frontend-cms && npm run test --if-present"

# Security
SECURITY_AUDIT_CMD="npm audit --audit-level=moderate 2>/dev/null || true"
SECURITY_HTML_CMD=""
SECURITY_EXTRA_CMD=""

# Version source: file-based (VERSION file)
VERSION_SOURCE="file"
VERSION_FILE="VERSION"
